# ============================================
# Mem0 Dashboard 项目 .gitignore
# ============================================

# 配置文件（含敏感信息，使用 config.yaml.example 作为模板）
config.yaml

# SQLite 数据库文件
access_logs.db

# Qdrant 向量数据库本地存储
qdrant_data/

# Python 缓存
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# 虚拟环境
venv/
.venv/
env/

# 日志文件
*.log

# 编辑器/系统文件
.DS_Store
*.swp
*.swo
Thumbs.db
.vscode/
.idea/

# 环境变量文件
.env
.env.local
.env.*.local

# SSL 证书文件（敏感，禁止提交）
nginx/ssl/*.pem
nginx/ssl/*.key
nginx/ssl/*.crt

# Docker 数据卷
docker-data/

# SQLite WAL 文件
access_logs.db-shm
access_logs.db-wal
