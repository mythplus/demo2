# ============================================
# Mem0 Dashboard 前端 Docker 构建排除文件
# 作用：减小构建上下文体积 + 避免 .env.local 等敏感/开发文件被 COPY 进镜像
# ============================================

# Node 依赖与构建产物
node_modules
.next
out
coverage
.turbo
tsconfig.tsbuildinfo

# Git
.git
.gitignore

# 环境变量（防止开发地址/密钥烘焙进生产 bundle）
.env
.env.local
.env.development
.env.test
.env.production
.env.*.local

# 测试
__tests__
jest.config.js
jest.setup.ts

# 编辑器 / 系统
.vscode
.idea
.workbuddy
.DS_Store
Thumbs.db
*.swp
*.swo
*.log

# Docker 自身（不必进构建上下文）
Dockerfile
.dockerignore

# 文档
README.md
