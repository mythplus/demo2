# Mem0 Dashboard 前端环境变量配置
# 复制此文件为 .env.local 并填入实际值

# 后端 API 地址（默认 http://localhost:8080）
NEXT_PUBLIC_MEM0_API_URL=http://localhost:8080

# API Key 认证密钥（需与后端 config.yaml 中 security.api_key 保持一致）
# 如果后端未配置 api_key，此项留空即可
#
# ⚠️ 安全警告：NEXT_PUBLIC_* 前缀的环境变量会在 `npm run build` 时被烘焙进前端 JS bundle，
# 任何访问站点的用户都可从浏览器 DevTools 中读取到明文值！
# 
# 生产环境推荐做法：
#   - 前端**留空**此变量
#   - 通过 Nginx 反向代理在服务端注入 `X-API-Key` 或 `Authorization: Bearer` 头
#   - 仅开发/内网调试可直接在此填入
NEXT_PUBLIC_MEM0_API_KEY=
