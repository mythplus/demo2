# ============================================
# Mem0 Dashboard 环境变量配置
# 复制此文件为 .env 并填入实际值
# Docker 部署和本地开发均使用此文件
# ============================================

# ---- Ollama 服务 ----
# 本地开发：http://localhost:11434
# Docker 部署：http://host.docker.internal:11434（访问宿主机 Ollama）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
EMBED_MODEL=nomic-embed-text

# ---- PostgreSQL 关系型数据库（日志、Webhook、记忆元数据） ----
# 格式：postgresql://user:password@host:port/dbname
# 也可以直接设置 DATABASE_URL 覆盖以下所有字段
#
# 安全说明：
# - 本地开发可以保持 POSTGRES_HOST=localhost 并按需留空密码。
# - 生产环境（MEM0_ENV=production）必须显式设置 POSTGRES_PASSWORD，
#   否则 config.py 会 fail fast 拒绝启动。
# - 请勿将真实密码提交到任何公开仓库；团队共享走七彩石/蓝盾等配置中心。
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mem0
POSTGRES_USER=mem0
POSTGRES_PASSWORD=
# DATABASE_URL=postgresql://mem0:your_password@your_host:5432/mem0

# ---- Qdrant 向量数据库（远程模式） ----
# 远程 Qdrant 服务的 IP 或域名
QDRANT_HOST=your_qdrant_host_here
# Qdrant HTTP 端口（默认 6333）
QDRANT_PORT=6333

# ---- Neo4j 图数据库 ----
# 本地开发：bolt://localhost:7687
# Docker 部署：bolt://neo4j:7687（使用 Docker 内部网络）
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ---- 安全配置 ----
# API 认证密钥（为空则不启用认证，生产环境必须设置！）
MEM0_API_KEY=mem0-test-123

# CORS 允许的来源（逗号分隔）
# 本地开发：http://localhost:3000,http://127.0.0.1:3000
# Docker 部署：https://your-domain.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- 服务配置 ----
# 后端端口
MEM0_PORT=8080

# 环境模式（production / development）
# production 模式：错误信息脱敏、多 Worker、禁用热重载
MEM0_ENV=development

# 生产环境 Worker 数量（默认 2，建议不超过 CPU 核数）
MEM0_WORKERS=2

# ---- Docker 部署专用 ----
# Nginx 对外暴露的端口
HTTP_PORT=80
HTTPS_PORT=443
