# Ollama 服务地址
OLLAMA_BASE_URL=http://9.134.231.238:11434
OLLAMA_MODEL=qwen2.5:7b
EMBED_MODEL=nomic-embed-text

# Neo4j 图数据库
NEO4J_URL=bolt://9.134.231.238:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mem0_neo4j_2024

# API 认证密钥（为空则不启用认证，建议生产环境设置）
