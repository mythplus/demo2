# ============================================
# Mem0 Dashboard 配置文件模板
# 复制此文件为 config.yaml 并填入实际值
# 支持环境变量替换：使用 ${ENV_VAR_NAME} 格式引用环境变量
#
# Docker 部署时，环境变量由 docker-compose.yml 中的 .env 文件注入
# 本地开发时，环境变量由项目根目录的 .env 文件注入
# ============================================

# LLM 大语言模型配置
# provider 支持: "ollama"（Ollama 原生）、"vllm"（vLLM 高性能推理）、"openai"（OpenAI 兼容）
# 使用 vLLM 时：provider 改为 "vllm"，配置 vllm_base_url 指向 vLLM 服务地址
llm:
  provider: "vllm"
  config:
    model: "${VLLM_MODEL}"
    vllm_base_url: "${VLLM_BASE_URL}"
    api_key: "${VLLM_API_KEY}"
    temperature: 0.1
    max_tokens: 8192

# --- 如果使用 Ollama 作为 LLM，取消下方注释并注释掉上方 vLLM 配置 ---
# llm:
#   provider: "ollama"
#   config:
#     model: "qwen2.5:7b"
#     ollama_base_url: "${OLLAMA_BASE_URL}"
#     temperature: 0.1

# Embedder 嵌入模型配置
embedder:
  provider: "ollama"
  config:
    model: "nomic-embed-text"
    ollama_base_url: "${OLLAMA_BASE_URL}"

# 向量数据库配置
vector_store:
  provider: "qdrant"
  config:
    collection_name: "mem0"
    embedding_model_dims: 768
    on_disk: true

# 图数据库配置
graph_store:
  provider: "neo4j"
  config:
    url: "${NEO4J_URL}"
    username: "${NEO4J_USER}"
    password: "${NEO4J_PASSWORD}"

# 安全配置
security:
  # API Key 认证（为空则不启用认证，建议生产环境必须设置）
  api_key: "${MEM0_API_KEY}"
  # CORS 允许的来源（逗号分隔，* 表示允许所有）
  # Docker 部署时建议设置为实际域名，如 "https://your-domain.com"
  cors_origins: "${CORS_ORIGINS}"
  # 速率限制（每分钟最大请求数，0 表示不限制）
  rate_limit: 60

# 版本号
version: "v1.1"
