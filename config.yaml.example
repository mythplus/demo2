# ============================================
# Mem0 Dashboard 配置文件模板
# 复制此文件为 config.yaml 并填入实际值
# 支持环境变量替换：使用 ${ENV_VAR_NAME} 格式引用环境变量
# ============================================

# LLM 大语言模型配置
llm:
  provider: "ollama"
  config:
    model: "qwen2.5:7b"
    ollama_base_url: "http://localhost:11434"
    temperature: 0.1

# Embedder 嵌入模型配置
embedder:
  provider: "ollama"
  config:
    model: "nomic-embed-text"
    ollama_base_url: "http://localhost:11434"

# 向量数据库配置
vector_store:
  provider: "qdrant"
  config:
    collection_name: "mem0"
    embedding_model_dims: 768
    on_disk: true

# 图数据库配置
graph_store:
  provider: "neo4j"
  config:
    url: "bolt://localhost:7687"
    username: "neo4j"
    password: "${NEO4J_PASSWORD}"

# 安全配置
security:
  # API Key 认证（为空则不启用认证，建议生产环境必须设置）
  api_key: "${MEM0_API_KEY}"
  # CORS 允许的来源（逗号分隔，* 表示允许所有）
  cors_origins: "http://localhost:3000,http://127.0.0.1:3000"
  # 速率限制（每分钟最大请求数，0 表示不限制）
  rate_limit: 60

# 版本号
version: "v1.1"
